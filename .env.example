# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# DynamoDB
DYNAMODB_TABLE_NAME=articles
DYNAMODB_ENDPOINT=http://localhost:4566  # LocalStack endpoint for local dev

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Application
LOG_LEVEL=info
TOP_N_ARTICLES=5
USE_MOCK_LLM=true
ENVIRONMENT=dev
